<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
                Mr.Rétro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a href="{{ path('app_games') }}" class="nav-link">Liste des jeux</a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_consoles') }}" class="nav-link">Liste des consoles</a>
                    </li>

                    {% if app.user %}
                        <li class="nav-item">
                            <a href="{{ path('app_profile') }}" class="nav-link">
                                {% if app.user.userProfilImage %}
                                    <img src="{{ asset(app.user.userProfilImage) }}" alt="Photo de profil" class="img-fluid rounded-circle border bg-light" style="max-width: 30px;">
                                {% else %}
                                    <img src="{{ asset('images/user_default.png') }}" alt="Avatar par défaut" class="img-fluid rounded-circle border bg-light" style="max-width: 30px;">
                                {% endif %}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_logout') }}" class="nav-link">Se déconnecter</a>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a href="{{ path('app_register') }}" class="nav-link">S'inscrire</a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_login') }}" class="nav-link">Se connecter</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
            <div class="nav-dot"></div>
        </div>
    </nav>
</header>