{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex align-items-center">
                    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary me-3" title="Retour à l'accueil">Retour à l'accueil</a>
                    <h1 class="card-title h4 mb-0">Mon profil</h1>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            {% if user.userProfilImage %}
                                <img src="{{ asset(user.userProfilImage) }}" alt="Photo de profil" class="img-fluid rounded-circle mb-3" style="max-width: 150px;">
                            {% else %}
                                <img src="{{ asset('images/user_default.png') }}" alt="Avatar par défaut" class="img-fluid rounded-circle mb-3" style="max-width: 150px;">
                            {% endif %}
                        </div>
                        <div class="col-md-8">
                            <dl class="row">
                                {% if user.id == app.user.id %}
                                <div class="bg-light p-3 rounded">
                                    <small class="text-danger"><u>/!\ Informations personnelles - Seul vous pouvez les voir /!\ </u></small>
                                    <dt class="col-sm-4">Email :</dt>
                                    <dd class="col-sm-8">{{ user.email }}</dd>

                                    <dt class="col-sm-4">Nom :</dt>
                                    <dd class="col-sm-8">{{ user.userLastname }}</dd>

                                    <dt class="col-sm-4">Prénom :</dt>
                                    <dd class="col-sm-8">{{ user.userName }}</dd>
                                </div>
                                {% endif %}

                                <dt class="col-sm-4 pt-3">Pseudo :</dt>
                                <dd class="col-sm-8 pt-3">{{ user.userUsername ?: 'Non défini' }}</dd>

                                <dt class="col-sm-4">Description :</dt>
                                <dd class="col-sm-8">{{ user.userDesc ?: 'Aucune description' }}</dd>

                                <hr>
                                <dt class="col-sm-4">Date d'inscription :</dt>
                                <dd class="col-sm-8">{{ user.userCreationDate|date('d/m/Y') }}</dd>

                                <dt class="col-sm-4">Date de dernière modification :</dt>
                                <dd class="col-sm-8">{{ user.userModifDate|date('d/m/Y') }}</dd>
                            </dl>

                            <div class="mt-4">
                                {% if user.id == app.user.id %}
                                <a href="{{ path('app_profile_edit') }}" class="btn btn-primary">
                                    <i class="fas fa-edit"></i> Modifier mon profil
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    {# Liste des Articles postés par l'utilisateur #}
    <div class="row justify-content-center mt-5">
        <div class="col-lg-8">
            {% if user.id == app.user.id %}
            <h2 class="mb-4">Mes articles</h2>
            {% else %}
            <h2 class="mb-4">Article de l'utilisateur</h2>
            {% endif %}

            {# Affiche un message si l'utilisateur n'a pas encore publié d'article #}
            {% if articles is empty %}
                <div class="alert alert-info">Vous n'avez pas encore publié d'article.</div>
                <a href="{{ path('app_game_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Poster votre premier article
                </a>
            {% else %}
                <div class="list-group">
                    {% for article in articles %}
                        <a href="{{ path('app_game_show', {'id': article.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            {{ article.articleName }}
                            <span class="badge bg-secondary">{{ article.articleCreationDate|date('d/m/Y') }}</span>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}