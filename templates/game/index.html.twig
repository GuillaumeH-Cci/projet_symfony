{% extends 'base.html.twig' %}

{% block title %}Liste des jeux{% endblock %}

{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h1 class="mb-0">Liste des jeux</h1>
                <a href="{{ path('app_game_new') }}" class="btn btn-primary">Ajouter un jeu</a>
            </div>

            {% if articles is empty %}
                <div class="alert alert-info">Aucun jeu n'est disponible pour le moment.</div>
            {% else %}
                <div class="row row-cols-1 row-cols-md-2 g-4">
                    {% for article in articles %}
                        <div class="col">
                                <div class="card h-100 shadow-sm">
                                    <a href="{{ path('app_game_show', {'id': article.id}) }}" class="stretched-link text-decoration-none text-dark">
                                    {% if article.articleThumbnail is null %}
                                        <img src="{{ asset('images/no-thumbnail.png') }}" class="card-img-top" alt="Pas de miniature disponible">
                                    {% else %}
                                        <img src="{{ asset('uploads/thumbnails/' ~ article.articleThumbnail) }}" class="card-img-top" alt="{{ article.articleName }}">
                                    {% endif %}
                                    <div class="card-body d-flex flex-column">
                                        <h2 class="card-title h5">{{ article.articleName }}</h2>
                                        <p class="card-text mb-2">{{ article.articleDesc|length > 150 ? article.articleDesc|slice(0, 150) ~ '…' : article.articleDesc }}</p>
                                        <div class="mt-auto">
                                            <p class="mb-1"><strong>Joueurs :</strong> {{ article.articleNbrPlayer }}</p>
                                            <p class="mb-1"><strong>Plateformes :</strong>
                                                {% if article.plat is empty %}
                                                    Aucune
                                                {% else %}
                                                    {% set platformNames = [] %}
                                                    {% for plat in article.plat %}
                                                        {% set platformNames = platformNames|merge([plat.platName]) %}
                                                    {% endfor %}
                                                    {{ platformNames|join(', ') }}
                                                {% endif %}
                                            </p>
                                            <p class="text-muted small">Ajouté le {{ article.articleCreationDate ? article.articleCreationDate|date('d/m/Y') : '—' }}</p>
                                            <p class="text-muted">
                                                Créé par :  
                                                
                                                <a href="{{ path('app_user_update', {'id': article.usr.id}) }}" class="d-flex align-items-center text-decoration-none text-dark">
                                                    {% if article.usr.userProfilImage is null %}
                                                    <img src="{{ asset('profile-pics/user-default.png') }}" alt="Avatar par défaut" class="rounded-circle me-2" width="30" height="30">
                                                    {% else %}
                                                    <img src="{{ asset('uploads/profile-pics/' ~ article.usr.userProfilImage) }}" alt="Avatar de {{ article.usr.username }}" class="rounded-circle me-2" width="30" height="30">
                                                    {% endif %}
                                                    {{ article.usr.username }}
                                                </a>   
                                            </p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
