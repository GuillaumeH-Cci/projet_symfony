{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h1 class="card-title h4 mb-4">Créer un compte</h1>

                    {{ form_start(registrationForm, {'attr': {'class': 'needs-validation'}}) }}
                        <div class="mb-3">
                            {{ form_row(registrationForm.email) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(registrationForm.user_lastname) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(registrationForm.user_name) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(registrationForm.user_username) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(registrationForm.plainPassword.first) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(registrationForm.plainPassword.second) }}
                        </div>
                        <div class="d-grid">
                            {{ form_widget(registrationForm.submit) }}
                        </div>
                    {{ form_end(registrationForm) }}
                </div>
            </div>
        </div>
    </div>

    {% if not registrationForm.vars.valid %}
    <div class="alert alert-danger">
        <ul>
            {% for error in registrationForm.vars.errors %}
                <li>{{ error.message }}</li>
            {% endfor %}
            {# Affiche aussi les erreurs des champs spécifiques (comme le mot de passe qui ne matche pas) #}
            {% for child in registrationForm.children %}
                {% for error in child.vars.errors %}
                    <li>{{ child.vars.label }}: {{ error.message }}</li>
                {% endfor %}
            {% endfor %}
        </ul>
    </div>
{% endif %}

{% endblock %}
