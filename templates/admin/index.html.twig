{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}

{# Section pour les utilisateurs #}
<div class="container mt-4">
    <h1>Admin Dashboard</h1>

    <form method="GET">
        <div class="input-group mb-3">
            <input type="text" class="form-control" 
                placeholder="Rechercher par nom..." aria-label="Rechercher par nom..." 
                name="search_name" id="search_name" value="{{ searchName }}">

            <button class="btn btn-outline-secondary" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>

    <div class="count mb-2">
        {{ users.getTotalItemCount }} Utilisateur(s) trouvé(s) !
    </div>

    <h2>Liste des utilisateurs :</h2>
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Roles</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.username }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.roles|join(', ') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="navigation">
    {{ knp_pagination_render(users) }}
    </div>

</div>   

<hr class="my-5">

{# Section pour les articles #}
<div class="container mt-4 mb-5">
    <form method="GET">
        <div class="input-group mb-3">
            <input type="text" class="form-control" 
                placeholder="Rechercher par nom..." aria-label="Rechercher par nom..." 
                name="search_name" id="search_name" value="{{ searchName }}">

            <button class="btn btn-outline-secondary" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>

    <div class="count mb-2">
    {{ articles.getTotalItemCount }} Article(s) trouvé(s) !
    </div>

    <h2>Liste des posts :</h2>
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            {% for article in articles %}
                <tr>
                    <td>{{ article.id }}</td>
                    <td>{{ article.articleName }}</td>
                    <td>{{ article.usr.userusername }}</td>
                    <td>{{ article.articlecreationdate|date('Y-m-d H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="navigation">
        {{ knp_pagination_render(articles) }}
    </div>

</div>
{% endblock %}
