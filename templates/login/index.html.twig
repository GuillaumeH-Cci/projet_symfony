{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}

{% if error %}
    <div class="alert alert-danger" role="alert">
        {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
{% endif %}

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h1 class="card-title h4 mb-4">Connexion</h1>
                        {{ form_start(loginForm) }}
                        <div class="mb-3">
                            {{ form_row(loginForm.email) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(loginForm.password) }}
                        </div>
                        <div class="d-grid">
                            {{ form_widget(loginForm.submit) }}
                        </div>
                        {{ form_end(loginForm) }}
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 text-center">
        <a href="{{ path('app_register') }}">Créer un compte</a>
    </div>
    {# Préparation pour la fonctionnalité de mot de passe oublié, à activer une fois la route créée 
        <div>
            <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
        </div> 
    #}
{% endblock %}
