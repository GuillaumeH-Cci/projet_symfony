{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm mt-5">
                <div class="card-body">
                    <h1 class="card-title h4 mb-4 text-center">Connexion</h1>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('app_login') }}" method="post" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="inputEmail" class="form-label">Adresse Email</label>
                            <input type="email" value="{{ last_username }}" id="inputEmail" name="_username"
                                   class="form-control" placeholder="votre@email.fr" required autofocus>
                        </div>

                        <div class="mb-3">
                            <label for="inputPassword" class="form-label">Mot de passe</label>
                            <input type="password" id="inputPassword" name="_password"
                                   class="form-control" required>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary mt-3">Se connecter</button>
                        </div>
                    </form>

                    <div class="mt-3 text-center">
                        <a href="{{ path('app_register') }}">Créer un compte</a>
                    </div>
                    {# Préparation pour la fonctionnalité de mot de passe oublié, à activer une fois la route créée 
                        <div>
                            <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                        </div> 
                    #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
