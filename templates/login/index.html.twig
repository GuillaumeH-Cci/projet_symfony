{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm mt-5">
                <div class="card-body">
                    <h1 class="card-title h4 mb-4 text-center">Connexion</h1>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('app_login') }}" method="post" class="needs-validation" novalidate>
                        {{ form_start(loginForm, {'attr': {'class': 'needs-validation'}}) }}
                        <div class="mb-3">
                            {{ form_row(loginForm.email) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(loginForm.password) }}
                        </div>
                        <div class="d-grid">
                            {{ form_widget(loginForm.submit) }}
                        </div>
                        {{ form_end(loginForm) }}
                    </form>

                    <div class="mt-3 text-center">
                        <a href="{{ path('app_register') }}">Créer un compte</a>
                    </div>
                    {# Préparation pour la fonctionnalité de mot de passe oublié, à activer une fois la route créée 
                        <div>
                            <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                        </div> 
                    #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
