{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm mt-5">
                <div class="card-body">
                    <h1 class="card-title h4 mb-4 text-center">Connexion</h1>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('app_login') }}" method="post" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="username">Email</label>
                            <input type="email" value="{{ email }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
                        </div>
                        <div class="mb-3">
                           <label for="password">Mot de passe</label>
                            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-lg btn-primary" type="submit">
                                Se connecter
                            </button>
                        </div>
                        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                    </form>

                    <div class="mt-3 text-center">
                        <a href="{{ path('app_register') }}">Créer un compte</a>
                    </div>
                    {# Préparation pour la fonctionnalité de mot de passe oublié, à activer une fois la route créée 
                        <div>
                            <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
                        </div> 
                    #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
