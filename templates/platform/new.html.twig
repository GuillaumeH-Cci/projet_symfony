{% extends 'base.html.twig' %}

{% block title %}Ajouter une console{% endblock %}

{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-10 col-lg-6">
            <h1 class="mb-4">Ajouter une console</h1>

            {{ form_start(consoleForm, {'attr': {'class': 'needs-validation'}}) }}
                <div class="mb-3">
                    {{ form_row(consoleForm.plat_name) }}
                </div>
                {{ form_widget(consoleForm.submit) }}
            {{ form_end(consoleForm) }}
        </div>
    </div>
{% endblock %}
